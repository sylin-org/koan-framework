<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
  </PropertyGroup>

  <ItemGroup>
    <!-- One reference brings the framework: Sylin.Koan.App = Koan core + Koan.Web.
         Sqlite is the data store for this template. Reference = Intent — no AddX() calls. -->
    <PackageReference Include="Sylin.Koan.App" Version="0.17.*" />
    <PackageReference Include="Sylin.Koan.Data.Connector.Sqlite" Version="0.17.*" />
  </ItemGroup>

</Project>

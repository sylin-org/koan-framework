<Project>
  <!--
    P1.1 · Composition lockfile (build-time emitter).

    NuGet auto-imports build/<PackageId>.targets for PackageReference consumers, so referencing
    Sylin.Koan.Core gives an app a checked-in koan.lock.json refreshed on every build — `git diff`
    then shows composition drift in PR review WITHOUT booting the app. The boot-time host writes the
    richer resolved twin (obj/koan.lock.resolved.json) and compares.

    Build-time we can honestly emit only app + modules (capabilities/elections/entities are
    runtime-negotiated — ARCH-0084). Module versions are major.minor (ARCH-0085 pre-1.0 breaking
    tier) so the checked-in file is byte-stable across commits and diffs stay meaningful.

    Scope: app projects (OutputType=Exe) by default; force on/off with $(KoanComposition)=true|false.
    In-repo (ProjectReference) NuGet does not auto-import this — the dogfood sample imports it
    explicitly; real consumers get it via PackageReference.
  -->
  <PropertyGroup>
    <_KoanCompositionEnabled Condition="'$(KoanComposition)' == 'true'">true</_KoanCompositionEnabled>
    <_KoanCompositionEnabled Condition="'$(_KoanCompositionEnabled)' == '' and '$(KoanComposition)' != 'false' and '$(OutputType)' == 'Exe'">true</_KoanCompositionEnabled>
    <!-- obj/ root (BaseIntermediateOutputPath is set in SDK props, available at this import; content is
         config-independent so the shared path is safe with WriteOnlyWhenDifferent). -->
    <_KoanModuleManifestFile>$(BaseIntermediateOutputPath)koan.modules.manifest</_KoanModuleManifestFile>
  </PropertyGroup>

  <!-- Declared statically so the resource is in @(EmbeddedResource) from evaluation (a target adding it later
       misses the resource pipeline's snapshot). The file content is produced by KoanWriteModuleManifest before
       CoreCompile; with LogicalName set, nothing reads the file until Csc embeds it. -->
  <ItemGroup Condition="'$(_KoanCompositionEnabled)' == 'true'">
    <EmbeddedResource Include="$(_KoanModuleManifestFile)" LogicalName="koan.modules.manifest" Visible="false" />
  </ItemGroup>

  <UsingTask TaskName="WriteKoanLockfile"
             TaskFactory="RoslynCodeTaskFactory"
             AssemblyFile="$(MSBuildToolsPath)\Microsoft.Build.Tasks.Core.dll">
    <ParameterGroup>
      <ModuleAssemblies ParameterType="Microsoft.Build.Framework.ITaskItem[]" Required="true" />
      <AppName ParameterType="System.String" Required="true" />
      <Tfm ParameterType="System.String" Required="true" />
      <OutputPath ParameterType="System.String" Required="true" />
    </ParameterGroup>
    <Task>
      <Using Namespace="System" />
      <Using Namespace="System.IO" />
      <Using Namespace="System.Linq" />
      <Using Namespace="System.Text" />
      <Using Namespace="System.Reflection" />
      <Using Namespace="System.Collections.Generic" />
      <Code Type="Fragment" Language="cs"><![CDATA[
        Func<Version, string> majorMinor = v => v == null ? "0.0" : v.Major + "." + v.Minor;
        Func<string, string> esc = s => (s ?? "").Replace("\\", "\\\\").Replace("\"", "\\\"");

        var modules = new List<KeyValuePair<string, string>>();
        string koan = null;
        foreach (var item in ModuleAssemblies)
        {
            var path = item.GetMetadata("FullPath");
            if (string.IsNullOrEmpty(path) || !File.Exists(path)) continue;
            var id = Path.GetFileNameWithoutExtension(path);
            Version ver = null;
            try { ver = AssemblyName.GetAssemblyName(path).Version; } catch { }
            var mm = majorMinor(ver);
            modules.Add(new KeyValuePair<string, string>(id, mm));
            if (string.Equals(id, "Koan.Core", StringComparison.Ordinal)) koan = mm;
        }

        var distinct = modules
            .GroupBy(m => m.Key, StringComparer.Ordinal)
            .Select(g => g.First())
            .OrderBy(m => m.Key, StringComparer.Ordinal)
            .ToList();
        if (koan == null) koan = distinct.Count > 0 ? distinct[0].Value : "0.0";

        var sb = new StringBuilder();
        sb.Append("{\n");
        sb.Append("  \"schema\": 1,\n");
        sb.Append("  \"app\": {\n");
        sb.Append("    \"name\": \"" + esc(AppName) + "\",\n");
        sb.Append("    \"koan\": \"" + esc(koan) + "\",\n");
        sb.Append("    \"tfm\": \"" + esc(Tfm) + "\"\n");
        sb.Append("  },\n");
        sb.Append("  \"modules\": [");
        for (int i = 0; i < distinct.Count; i++)
        {
            sb.Append(i == 0 ? "\n" : ",\n");
            sb.Append("    {\n");
            sb.Append("      \"id\": \"" + esc(distinct[i].Key) + "\",\n");
            sb.Append("      \"version\": \"" + esc(distinct[i].Value) + "\"\n");
            sb.Append("    }");
        }
        sb.Append(distinct.Count == 0 ? "]\n" : "\n  ]\n");
        sb.Append("}\n");
        var content = sb.ToString();

        // Write only when the content changes — avoids touch churn, rebuild loops, and noisy diffs.
        string existing = File.Exists(OutputPath) ? File.ReadAllText(OutputPath) : null;
        if (!string.Equals(existing, content, StringComparison.Ordinal))
        {
            File.WriteAllText(OutputPath, content);
            Log.LogMessage(MessageImportance.Normal, "Koan composition: wrote " + OutputPath + " (" + distinct.Count + " modules).");
        }
      ]]></Code>
    </Task>
  </UsingTask>

  <Target Name="KoanWriteCompositionLockfile"
          AfterTargets="Build"
          Condition="'$(_KoanCompositionEnabled)' == 'true' and '$(DesignTimeBuild)' != 'true'">
    <ItemGroup>
      <_KoanModuleAssembly Include="@(ReferencePath)"
                           Condition="$([System.String]::Copy('%(Filename)').StartsWith('Koan.'))" />
    </ItemGroup>
    <WriteKoanLockfile ModuleAssemblies="@(_KoanModuleAssembly)"
                       AppName="$(AssemblyName)"
                       Tfm="$(TargetFramework)"
                       OutputPath="$(MSBuildProjectDirectory)\koan.lock.json" />
  </Target>

  <!--
    X-aot-substrate · Boot module manifest (embedded). Reference=Intent connectors are referenced via
    <ProjectReference> but never symbol-used, so the compiler drops them from the app's metadata (the boot
    reference-fixpoint can't see them) and a single-file publish leaves no loose Koan.*.dll to scan. The same
    @(ReferencePath) Koan-filter that drives the lockfile is written one-name-per-line and EMBEDDED in the app
    assembly — embedded resources survive single-file bundling, so AppBootstrapper.LoadIntentModulesFromManifest
    can Assembly.Load each module by name at boot. Runs before CoreCompile so the resource is included; only for
    app projects that opt into composition (same gate as the lockfile).
  -->
  <Target Name="KoanWriteModuleManifest"
          BeforeTargets="PrepareResources;CoreCompile"
          DependsOnTargets="ResolveAssemblyReferences"
          Condition="'$(_KoanCompositionEnabled)' == 'true' and '$(DesignTimeBuild)' != 'true'">
    <ItemGroup>
      <_KoanManifestModule Include="@(ReferencePath)"
                           Condition="$([System.String]::Copy('%(Filename)').StartsWith('Koan.'))" />
    </ItemGroup>
    <WriteLinesToFile File="$(_KoanModuleManifestFile)"
                      Lines="@(_KoanManifestModule->'%(Filename)')"
                      Overwrite="true"
                      WriteOnlyWhenDifferent="true" />
    <ItemGroup>
      <FileWrites Include="$(_KoanModuleManifestFile)" />
    </ItemGroup>
  </Target>
</Project>

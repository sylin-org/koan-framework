<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <Description>Composition and runtime substrate for Koan modules: lifecycle, context, provider catalogs, readiness, discovery, facts, and build provenance.</Description>
    <PackageTags>$(CommonPackageTags);core;composition;modules;context;readiness;discovery;runtime-facts;provenance</PackageTags>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" Version="10.0.8" />
    <PackageReference Include="Microsoft.Extensions.Options" Version="10.0.8" />
    <PackageReference Include="Microsoft.Extensions.Configuration.Abstractions" Version="10.0.8" />
    <PackageReference Include="Microsoft.Extensions.Configuration" Version="10.0.8" />
    <PackageReference Include="Microsoft.Extensions.Configuration.Binder" Version="10.0.8" />
    <PackageReference Include="Microsoft.Extensions.Options.ConfigurationExtensions" Version="10.0.8" />
    <PackageReference Include="Microsoft.Extensions.Options.DataAnnotations" Version="10.0.8" />
    <PackageReference Include="Microsoft.Extensions.Logging" Version="10.0.8" />
    <PackageReference Include="Microsoft.Extensions.Logging.Console" Version="10.0.8" />
    <PackageReference Include="Microsoft.Extensions.Hosting.Abstractions" Version="10.0.8" />
    <!-- OTel SDK extracted to the Koan.Observability package (ARCH-0088, Reference=Intent). -->
    <PackageReference Include="Newtonsoft.Json" Version="13.0.4" />
  </ItemGroup>
  <!-- P1.1: ship the composition-lockfile target as a transitive build asset. Applications normally
       reference a Koan bundle rather than Core directly; buildTransitive preserves Reference = Intent
       across that dependency edge. Remove-then-Include avoids the default-None-glob duplicate. -->
  <ItemGroup>
    <None Remove="build/Sylin.Koan.Core.targets" />
    <None Include="build/Sylin.Koan.Core.targets" Pack="true" PackagePath="buildTransitive/Sylin.Koan.Core.targets" />
    <None Remove="build/tools/Sylin.Koan.SemanticActivation.targets" />
    <None Include="build/tools/Sylin.Koan.SemanticActivation.targets"
          Pack="true"
          PackagePath="buildTransitive/tools/Sylin.Koan.SemanticActivation.targets" />
    <None Include="$(MSBuildProjectDirectory)\..\Koan.Core.Registry.Generators\bin\$(Configuration)\netstandard2.0\Koan.Core.Registry.Generators.dll"
          Pack="true"
          PackagePath="buildTransitive/tools/Koan.Core.Registry.Generators.dll"
          Visible="false" />
    <!-- Core owns the generator as package payload. These evaluated source inputs feed the release
         lineage compiler, so any generator change mints a fresh Core identity automatically. -->
    <KoanPackageInput Include="$(MSBuildProjectDirectory)\..\Koan.Core.Registry.Generators\Koan.Core.Registry.Generators.csproj;
                               $(MSBuildProjectDirectory)\..\Koan.Core.Registry.Generators\**\*.cs;
                               $(MSBuildProjectDirectory)\..\Koan.Core.Registry.Generators\version.json"
                      Exclude="$(MSBuildProjectDirectory)\..\Koan.Core.Registry.Generators\bin\**;
                               $(MSBuildProjectDirectory)\..\Koan.Core.Registry.Generators\obj\**" />
  </ItemGroup>
</Project>

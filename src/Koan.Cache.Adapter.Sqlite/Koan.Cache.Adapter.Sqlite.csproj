<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <LangVersion>latest</LangVersion>
    <AssemblyName>Koan.Cache.Adapter.Sqlite</AssemblyName>
    <RootNamespace>Koan.Cache.Adapter.Sqlite</RootNamespace>
    <Description>SQLite-backed persistent L1 cache store for Koan.Cache. Provides on-disk cache persistence with tag indexing and TTL eviction. Preempts the default Memory store by ProviderPriority.</Description>
    <PackageTags>$(CommonPackageTags);cache;adapter;sqlite;l1;persistent</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Data.Sqlite" Version="10.0.8" />
    <!-- Transitive-override for NU1903 (GHSA-2m69-gcr7-jv3q): pin the native SQLite binary to the
         patched 3.50.3; Microsoft.Data.Sqlite's managed SQLitePCLRaw.core stays 2.1.11. -->
    <PackageReference Include="SQLitePCLRaw.lib.e_sqlite3" Version="3.50.3" />
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" Version="10.0.8" />
    <PackageReference Include="Microsoft.Extensions.Options" Version="10.0.8" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Koan.Cache\Koan.Cache.csproj"
                      />
    <ProjectReference Include="..\Koan.Cache.Abstractions\Koan.Cache.Abstractions.csproj" />
    <ProjectReference Include="..\Koan.Core\Koan.Core.csproj" />
  </ItemGroup>
</Project>

<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <KoanPackageKind>Periphery</KoanPackageKind>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <Description>ASP.NET Core integration for Koan: controller-first routing, health endpoints, and well-known endpoints (incl. observability reporting). OTel wiring lives in the opt-in Koan.Observability package (ARCH-0088).</Description>
    <PackageTags>$(CommonPackageTags);web;aspnetcore;controllers;health;swagger-ready;observability</PackageTags>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.Mvc.NewtonsoftJson" Version="10.0.8" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\Koan.Data.Core\Koan.Data.Core.csproj" />
    <ProjectReference Include="..\Koan.Data.Abstractions\Koan.Data.Abstractions.csproj" />
    <ProjectReference Include="..\Koan.Core\Koan.Core.csproj" />
  </ItemGroup>
</Project>
<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <KoanPackageKind>Periphery</KoanPackageKind>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <AssemblyName>Koan.Tenancy</AssemblyName>
    <RootNamespace>Koan.Tenancy</RootNamespace>
    <Description>First-class multi-tenancy for Koan (ARCH-0095): the Tenant ambient surface (Tenant.Use/.WithTenant/None), [HostScoped], and the fail-closed tenant gate — registered as contributors to the Koan.Data.Core storage pipeline (DATA-0105) under Reference = Intent. The data core stays tenancy-agnostic.</Description>
    <PackageTags>$(CommonPackageTags);tenancy;multitenant;isolation;saas</PackageTags>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\Koan.Core\Koan.Core.csproj" />
    <ProjectReference Include="..\Koan.Data.Abstractions\Koan.Data.Abstractions.csproj" />
    <ProjectReference Include="..\Koan.Data.Core\Koan.Data.Core.csproj" />
  </ItemGroup>
</Project>

<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <KoanPackageKind>Periphery</KoanPackageKind>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <AssemblyName>Koan.Identity.Passwords</AssemblyName>
    <RootNamespace>Koan.Identity.Passwords</RootNamespace>
    <Description>SEC-0007 P3 group 4 — the optional local-password factor (off by default, D4). A LocalCredential Entity&lt;T&gt; stores a PORTABLE BCrypt PHC/MCF hash (D2 — no bespoke auth-storage adapter), verify with upgrade-on-verify rehash, and a Security Checkup contributor. Reference = Intent.</Description>
    <PackageTags>$(CommonPackageTags);identity;password;bcrypt;credentials</PackageTags>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="BCrypt.Net-Next" Version="4.0.3" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\Koan.Identity.Credentials\Koan.Identity.Credentials.csproj" />
  </ItemGroup>
  <ItemGroup>
    <AssemblyAttribute Include="System.Runtime.CompilerServices.InternalsVisibleTo">
      <_Parameter1>Koan.Identity.Tests</_Parameter1>
    </AssemblyAttribute>
  </ItemGroup>
</Project>

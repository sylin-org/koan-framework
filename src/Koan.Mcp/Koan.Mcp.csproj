<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <Description>Model Context Protocol integration for Koan entity endpoints: discovery, schema, execution, and transports.</Description>
    <PackageTags>$(CommonPackageTags);mcp;jsonrpc;llm;entity;agent</PackageTags>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="StreamJsonRpc" />
    <!-- Transitive-vulnerability override: StreamJsonRpc 2.22.23 pulls MessagePack 2.5.192,
         affected by CVE-2026-48109 (GHSA-hv8m-jj95-wg3x, high/8.2 LZ4 out of bounds read DoS). Pin
         the patched 2.5.301 (API-compatible 2.5.x line). Koan.Mcp is the only direct StreamJsonRpc
         referencer, so this floor propagates to every MCP consumer. Remove once StreamJsonRpc's own
         MessagePack floor is 2.5.301 or higher. -->
    <PackageReference Include="MessagePack" />
    <PackageReference Include="Newtonsoft.Json" />
    <PackageReference Include="Microsoft.AspNetCore.JsonPatch" />
  <PackageReference Include="Jint" />
  <!-- Explicitly include Acornima to satisfy deps manifest when running tests under net10 preview -->
  <PackageReference Include="Acornima" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\Koan.Core\Koan.Core.csproj" />
    <ProjectReference Include="..\Koan.Data.Core\Koan.Data.Core.csproj" />
    <ProjectReference Include="..\Koan.Web\Koan.Web.csproj" />
    <ProjectReference Include="..\Koan.Web.Sse\Koan.Web.Sse.csproj" />
    <!-- SEC-0006 D2/D3: the MCP edge is an OAuth resource server — it validates Koan.bearer tokens
         (scheme name) and enforces the RFC 8707 audience. One-way reference down to the trust pillar. -->
    <ProjectReference Include="..\Koan.Security.Trust\Koan.Security.Trust.csproj" />
  </ItemGroup>
</Project>

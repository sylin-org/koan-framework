<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <AssemblyName>Koan.Identity.Credentials</AssemblyName>
    <RootNamespace>Koan.Identity.Credentials</RootNamespace>
    <Description>SEC-0007 P3 group 4 — the shared base for the opt-in account-security factor family. Owns the framework-native 2-phase (interrupted → resume) step-up sign-in seam + amr/acr claims, the IPasswordHasher abstraction, and the Security Checkup contributor-pipeline read-model. Off by default (Reference = Intent); the factor packages (Koan.Identity.Passwords / .Mfa / .Passkeys) build on it.</Description>
    <PackageTags>$(CommonPackageTags);identity;credentials;mfa;step-up;security-checkup</PackageTags>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\Koan.Identity\Koan.Identity.csproj" />
  </ItemGroup>
  <ItemGroup>
    <AssemblyAttribute Include="System.Runtime.CompilerServices.InternalsVisibleTo">
      <_Parameter1>Koan.Identity.Tests</_Parameter1>
    </AssemblyAttribute>
  </ItemGroup>
</Project>

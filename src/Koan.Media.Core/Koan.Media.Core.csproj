<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <Description>Koan media runtime for Entity-backed originals, recipe discovery, validated image pipelines, rendering, and runtime facts.</Description>
    <PackageTags>$(CommonPackageTags);media;runtime;images;recipes;pipeline;derivative</PackageTags>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\Koan.Media.Abstractions\Koan.Media.Abstractions.csproj" />
    <ProjectReference Include="..\Koan.Storage\Koan.Storage.csproj" />
    <ProjectReference Include="..\Koan.Storage.Abstractions\Koan.Storage.Abstractions.csproj" />
    <ProjectReference Include="..\Koan.Data.Core\Koan.Data.Core.csproj" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Options" />
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.Options.ConfigurationExtensions" />
    <PackageReference Include="SixLabors.ImageSharp" />
    <!-- MEDIA-0004 overlays: ImageSharp.Drawing brings DrawImage (compositing),
         DrawText (text overlays), and Fill (background fills). Brings SixLabors.Fonts
         transitively for text rendering. -->
    <PackageReference Include="SixLabors.ImageSharp.Drawing" />
    <!-- MEDIA-0006: SVG decoder + Skia rasterizer. SkiaSharp + Svg.Skia provide
         the Vector → Raster bridge for SVG inputs. Native binaries are pulled per
         platform RID at publish time; the managed assembly weight is ~8.3 MiB.
         Windows natives come implicitly via the default SkiaSharp dependency chain. -->
    <PackageReference Include="SkiaSharp" />
    <PackageReference Include="Svg.Skia" />
    <PackageReference Include="SkiaSharp.NativeAssets.Linux" />
    <PackageReference Include="SkiaSharp.NativeAssets.macOS" />
  </ItemGroup>
</Project>

<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <KoanPackageKind>Periphery</KoanPackageKind>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <Description>Media core for Koan: Ensure, pipelines, ancestry, and URL helpers over Koan.Storage.</Description>
    <PackageTags>$(CommonPackageTags);media;images;video;pdf;pipeline;derivative</PackageTags>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\Koan.Media.Abstractions\Koan.Media.Abstractions.csproj" />
    <ProjectReference Include="..\Koan.Storage\Koan.Storage.csproj" />
    <ProjectReference Include="..\Koan.Data.Core\Koan.Data.Core.csproj" />
    <ProjectReference Include="..\Koan.Web\Koan.Web.csproj" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Options" Version="10.0.0" />
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" Version="10.0.0" />
    <PackageReference Include="Microsoft.Extensions.Options.ConfigurationExtensions" Version="10.0.0" />
    <PackageReference Include="SixLabors.ImageSharp" Version="3.1.12" />
    <!-- MEDIA-0004 overlays: ImageSharp.Drawing brings DrawImage (compositing),
         DrawText (text overlays), and Fill (background fills). Brings SixLabors.Fonts
         transitively for text rendering. -->
    <PackageReference Include="SixLabors.ImageSharp.Drawing" Version="2.1.6" />
  </ItemGroup>
</Project>
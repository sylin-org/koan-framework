<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <AssemblyName>Koan.Web.Auth.Roles</AssemblyName>
    <RootNamespace>Koan.Web.Auth.Roles</RootNamespace>
    <Description>Role attribution layer for Koan Web Auth: policy-backed role stores, attribute wiring, and controller extensions.</Description>
    <PackageTags>$(CommonPackageTags);web;auth;roles;authorization</PackageTags>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\Koan.Core\Koan.Core.csproj" />
    <ProjectReference Include="..\Koan.Data.Core\Koan.Data.Core.csproj" />
    <ProjectReference Include="..\Koan.Web.Extensions\Koan.Web.Extensions.csproj" />
    <!-- IKoanAuthEventContributor / contexts live in Koan.Web.Auth; Roles ships AdminBootstrapContributor. -->
    <ProjectReference Include="..\Koan.Web.Auth\Koan.Web.Auth.csproj" />
  </ItemGroup>
</Project>

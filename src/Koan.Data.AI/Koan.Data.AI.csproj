<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>

    <KoanPackageKind>Periphery</KoanPackageKind>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <LangVersion>latest</LangVersion>
    <Description>Entity-aware AI operations for Koan: EntityAi.Embed/Chat/Ocr, [Embedding] convention defaults, [MediaAnalysis] auto-processing pipeline, and cross-modal search via the MediaAnalysisEmbeddingBridge.</Description>
    <PackageTags>$(CommonPackageTags);ai;embedding;rag;media-analysis;entity</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="Koan.Tests.AI.Unit" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Koan.Data.Abstractions\Koan.Data.Abstractions.csproj" />
    <ProjectReference Include="..\Koan.Data.Core\Koan.Data.Core.csproj" />
    <ProjectReference Include="..\Koan.Data.Vector\Koan.Data.Vector.csproj" />
    <ProjectReference Include="..\Koan.AI.Contracts\Koan.AI.Contracts.csproj" />
    <ProjectReference Include="..\Koan.AI\Koan.AI.csproj" />
    <ProjectReference Include="..\Koan.Core\Koan.Core.csproj" />
  </ItemGroup>

  <ItemGroup>
    <!-- HealthChecks (IHealthCheck + services.AddHealthChecks()) for the AI health checks. Previously
         free-rode on Microsoft.AspNetCore.App leaked transitively through Koan.Core's OTel packages;
         declared explicitly now that OTel moved to Koan.Observability (ARCH-0088). -->
    <PackageReference Include="Microsoft.Extensions.Diagnostics.HealthChecks" Version="10.0.8" />
    <!-- Canonical serializer for the FullJson embedding text + migrator export (System.Text.Json's reflection
         serializer is disabled under NativeAOT). Used directly; declared explicitly rather than via transitive. -->
    <PackageReference Include="Newtonsoft.Json" Version="13.0.4" />
  </ItemGroup>

</Project>

<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <PackageValidationBaselineVersion>0.20.0</PackageValidationBaselineVersion>
    <AssemblyName>Koan.Data.Connector.ElasticSearch</AssemblyName>
    <RootNamespace>Koan.Data.Connector.ElasticSearch</RootNamespace>
    <Description>Elasticsearch vector adapter for Koan: index provisioning, kNN search, metadata filtering and health checks via the Elasticsearch REST API.</Description>
    <PackageTags>$(CommonPackageTags);data;vector;elasticsearch;knn</PackageTags>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\..\Koan.Core\Koan.Core.csproj" />
    <ProjectReference Include="..\..\..\Koan.Data.SearchEngine\Koan.Data.SearchEngine.csproj" />
    <PackageReference Include="Newtonsoft.Json" />
  </ItemGroup>
</Project>

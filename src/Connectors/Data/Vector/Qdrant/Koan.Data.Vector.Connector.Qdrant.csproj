<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <AssemblyName>Koan.Data.Vector.Connector.Qdrant</AssemblyName>
    <RootNamespace>Koan.Data.Vector.Connector.Qdrant</RootNamespace>
    <Description>Qdrant vector adapter for Koan — the lean cell: scalar quantization + on-disk originals tuned for resource-constrained deployments. Payload-based metadata filtering, REST-based KNN search, synchronous write semantics (wait=true). For full-featured / high-fidelity vector workloads prefer Koan.Data.Vector.Connector.Weaviate.</Description>
    <PackageTags>$(CommonPackageTags);data;vector;qdrant;knn</PackageTags>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\..\..\Koan.Data.Abstractions\Koan.Data.Abstractions.csproj" />
    <ProjectReference Include="..\..\..\..\Koan.Data.Vector.Abstractions\Koan.Data.Vector.Abstractions.csproj" />
    <ProjectReference Include="..\..\..\..\Koan.Data.Core\Koan.Data.Core.csproj" />
    <ProjectReference Include="..\..\..\..\Koan.Core\Koan.Core.csproj" />
    <ProjectReference Include="..\..\..\..\Koan.Orchestration.Abstractions\Koan.Orchestration.Abstractions.csproj" />
    <PackageReference Include="Microsoft.Extensions.Http" Version="10.0.8" />
    <PackageReference Include="Newtonsoft.Json" Version="13.0.4" />
  </ItemGroup>
</Project>

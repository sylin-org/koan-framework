<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <Description>Couchbase data provider for Koan: options binding and repository integration for document databases.</Description>
    <PackageTags>$(CommonPackageTags);data;couchbase;documentdb;repository</PackageTags>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\..\Koan.Data.Abstractions\Koan.Data.Abstractions.csproj" />
    <ProjectReference Include="..\..\..\Koan.Data.Core\Koan.Data.Core.csproj" />
    <ProjectReference Include="..\..\..\Koan.Core\Koan.Core.csproj" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="CouchbaseNetClient" />
    <PackageReference Include="Couchbase.Transactions" />
    <!-- Pin transitive Snappier to 1.3.1 to clear GHSA-pggp-6c3x-2xmx (HIGH).
         CouchbaseNetClient 3.8.1 still pulls Snappier 1.2.0 which is affected
         (advisory range <= 1.3.0). 1.3.1 is API-compatible. -->
    <PackageReference Include="Snappier" />
    <PackageReference Include="Microsoft.Extensions.Options" />
    <PackageReference Include="Microsoft.Extensions.Options.ConfigurationExtensions" />
    <PackageReference Include="Microsoft.Extensions.Options.DataAnnotations" />
  </ItemGroup>
</Project>

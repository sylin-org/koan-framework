<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <KoanPackageKind>Periphery</KoanPackageKind>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <Description>Outbox implementation for Koan CQRS using MongoDB.</Description>
    <PackageTags>$(CommonPackageTags);data;cqrs;outbox;mongodb</PackageTags>
  </PropertyGroup>
  <ItemGroup>
  <ProjectReference Include="..\..\..\..\..\Koan.Data.Cqrs\Koan.Data.Cqrs.csproj" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Hosting.Abstractions" Version="10.0.0" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="MongoDB.Driver" Version="3.8.1" />
    <!-- See Koan.Data.Connector.Mongo for rationale. -->
    <PackageReference Include="SharpCompress" Version="0.48.1" />
  </ItemGroup>
</Project>
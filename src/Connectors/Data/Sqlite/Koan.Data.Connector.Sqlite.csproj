<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <Description>SQLite provider for Koan relational data: lightweight local development and testing support.</Description>
    <PackageTags>$(CommonPackageTags);data;sqlite;relational;efcore</PackageTags>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\..\Koan.Data.Abstractions\Koan.Data.Abstractions.csproj" />
    <ProjectReference Include="..\..\..\Koan.Data.Core\Koan.Data.Core.csproj" />
    <ProjectReference Include="..\..\..\Koan.Data.Relational\Koan.Data.Relational.csproj" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.Data.Sqlite" Version="10.0.8" />
    <!-- Transitive-override: Microsoft.Data.Sqlite pulls the vulnerable native lib 2.1.11 (NU1903,
         GHSA-2m69-gcr7-jv3q). Pin just the native binary to the patched 3.50.3 (SQLite 3.50.3); the
         managed SQLitePCLRaw.core stays 2.1.11, so Microsoft.Data.Sqlite is unaffected. -->
    <PackageReference Include="SQLitePCLRaw.lib.e_sqlite3" Version="3.50.3" />
    <!-- Dapper removed (X-aot-substrate / S2): Dapper's GetTypeDeserializerImpl emits IL at runtime, which
         NativeAOT forbids (PlatformNotSupportedException). The SQLite read/write path now uses the hand-rolled,
         AOT-clean Koan.Data.Relational.Ado helpers. Non-AOT relational adapters can use Koan.Data.Relational.Dapper. -->
    <PackageReference Include="Newtonsoft.Json" Version="13.0.4" />
  </ItemGroup>
</Project>

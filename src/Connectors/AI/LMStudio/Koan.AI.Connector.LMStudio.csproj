<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <Description>LM Studio provider for Koan AI (chat, streaming, embeddings) with auto-discovery.</Description>
    <PackageTags>$(CommonPackageTags);ai;lmstudio;provider</PackageTags>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\..\Koan.Core\Koan.Core.csproj" />
    <ProjectReference Include="..\..\..\Koan.AI\Koan.AI.csproj" />
    <ProjectReference Include="..\..\..\Koan.AI.Contracts\Koan.AI.Contracts.csproj" />
  </ItemGroup>
  <ItemGroup>
    <!-- IHttpClientFactory. Previously free-rode on Microsoft.Extensions.Http leaked transitively through
         Koan.Core's OTel packages; declared explicitly now that OTel moved to Koan.Observability (ARCH-0088). -->
    <PackageReference Include="Microsoft.Extensions.Http" />
    <PackageReference Include="Newtonsoft.Json" />
  </ItemGroup>
</Project>


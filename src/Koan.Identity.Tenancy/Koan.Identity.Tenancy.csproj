<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <AssemblyName>Koan.Identity.Tenancy</AssemblyName>
    <RootNamespace>Koan.Identity.Tenancy</RootNamespace>
    <Description>SEC-0007 Layer 4 — the Identity × Tenancy bridge (Reference = Intent). Lights up membership-scoped access (the Membership effective-access contributor), the tenant-resolution carriers + AfterAuthentication middleware that scopes the request to a tenant, invite-binds-to-identity, and atomic verifiable deprovisioning. Koan.Identity core never references Koan.Tenancy (graceful degradation, D7); referencing this package composes the two.</Description>
    <PackageTags>$(CommonPackageTags);identity;tenancy;membership;multi-tenant;tenant-resolution</PackageTags>
  </PropertyGroup>
  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>
  <ItemGroup>
    <!-- SEC-0007 D7 — the bridge references BOTH pillars (the core references neither sibling). Koan.Identity brings
         Koan.Web.Auth / Koan.Core / Koan.Data.Core transitively; Koan.Web brings the pipeline-contributor seam. -->
    <ProjectReference Include="..\Koan.Identity\Koan.Identity.csproj" />
    <ProjectReference Include="..\Koan.Tenancy\Koan.Tenancy.csproj" />
    <ProjectReference Include="..\Koan.Web\Koan.Web.csproj" />
  </ItemGroup>
  <ItemGroup>
    <AssemblyAttribute Include="System.Runtime.CompilerServices.InternalsVisibleTo">
      <_Parameter1>Koan.Identity.Tests</_Parameter1>
    </AssemblyAttribute>
  </ItemGroup>
</Project>

<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <KoanPackageKind>Periphery</KoanPackageKind>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <Description>Cross-node push-dispatch for Koan.Jobs over Koan.Messaging. Referencing this package fans a lightweight "job ready" wake across nodes so workers claim newly-submitted work without waiting out the poll interval. The ledger remains the truth; the signal only trims dispatch latency.</Description>
    <PackageTags>$(CommonPackageTags);jobs;messaging;transport</PackageTags>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\Koan.Jobs\Koan.Jobs.csproj" />
    <ProjectReference Include="..\Koan.Core\Koan.Core.csproj" />
    <ProjectReference Include="..\Koan.Messaging.Core\Koan.Messaging.Core.csproj" />
  </ItemGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="Koan.Jobs.Transport.Messaging.Tests" />
  </ItemGroup>
</Project>

<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <KoanPackageKind>Periphery</KoanPackageKind>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <Description>First-class OpenAPI 3.1 registration for Koan web applications using Microsoft.AspNetCore.OpenApi.</Description>
    <PackageTags>$(CommonPackageTags);openapi;json-schema;documentation</PackageTags>
  </PropertyGroup>
  <ItemGroup>
  <PackageReference Include="Microsoft.AspNetCore.OpenApi" Version="10.0.8" />
  <PackageReference Include="Microsoft.OpenApi" Version="2.7.6" />
    <ProjectReference Include="..\Koan.Core\Koan.Core.csproj" />
    <ProjectReference Include="..\Koan.Web\Koan.Web.csproj" />
  </ItemGroup>
</Project>

<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <Description>OpenAPI 3.1 document and governed interactive UI projection for Koan web applications.</Description>
    <PackageTags>$(CommonPackageTags);openapi;json-schema;documentation</PackageTags>
  </PropertyGroup>
  <ItemGroup>
  <PackageReference Include="Microsoft.AspNetCore.OpenApi" Version="10.0.8" />
  <PackageReference Include="Microsoft.OpenApi" Version="2.7.6" />
  <PackageReference Include="Swashbuckle.AspNetCore.SwaggerUI" Version="6.6.2" />
    <ProjectReference Include="..\Koan.Core\Koan.Core.csproj" />
    <ProjectReference Include="..\Koan.Web\Koan.Web.csproj" />
  </ItemGroup>
</Project>

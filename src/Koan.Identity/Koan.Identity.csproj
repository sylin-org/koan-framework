<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <KoanPackageKind>Periphery</KoanPackageKind>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <AssemblyName>Koan.Identity</AssemblyName>
    <RootNamespace>Koan.Identity</RootNamespace>
    <Description>SEC-0007 — the durable person (Identity) and the sign-in → identity reconciliation seam. Implements Koan.Web.Auth's IUserStore / IExternalIdentityStore with Entity&lt;&gt;-backed durable stores, upserts an Identity from claims on every sign-in, and gives Membership.IdentityId a real backing entity. Reference = Intent.</Description>
    <PackageTags>$(CommonPackageTags);identity;person;user;auth;reconciliation</PackageTags>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\Koan.Core\Koan.Core.csproj" />
    <ProjectReference Include="..\Koan.Data.Core\Koan.Data.Core.csproj" />
    <!-- SEC-0007 D6: compose, don't duplicate. Koan.Identity references Koan.Web.Auth one-way to supply the
         IUserStore / IExternalIdentityStore the auth pillar defines. Web.Auth never references back up. -->
    <ProjectReference Include="..\Koan.Web.Auth\Koan.Web.Auth.csproj" />
  </ItemGroup>
  <ItemGroup>
    <AssemblyAttribute Include="System.Runtime.CompilerServices.InternalsVisibleTo">
      <_Parameter1>Koan.Identity.Tests</_Parameter1>
    </AssemblyAttribute>
  </ItemGroup>
</Project>

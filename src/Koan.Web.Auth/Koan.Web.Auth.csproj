<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <AssemblyName>Koan.Web.Auth</AssemblyName>
    <RootNamespace>Koan.Web.Auth</RootNamespace>
    <Description>Authentication core for Koan Web: IDP configuration, controller wiring, and claims transformation pipelines.</Description>
    <PackageTags>$(CommonPackageTags);web;auth;identity;openid</PackageTags>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\Koan.Core\Koan.Core.csproj" />
    <ProjectReference Include="..\Koan.Web.Auth.Abstractions\Koan.Web.Auth.Abstractions.csproj" />
    <ProjectReference Include="..\Koan.Web\Koan.Web.csproj" />
    <!-- SEC-0001: the trust fabric is a lower-level pillar; Web.Auth depends on it one-way and calls
         into it to attach the inbound bearer scheme alongside the cookie scheme. -->
    <ProjectReference Include="..\Koan.Security.Trust\Koan.Security.Trust.csproj" />
  </ItemGroup>
  <ItemGroup>
    <AssemblyAttribute Include="System.Runtime.CompilerServices.InternalsVisibleTo">
      <_Parameter1>Koan.Web.Auth.Tests</_Parameter1>
    </AssemblyAttribute>
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.Authentication.OpenIdConnect" Version="10.0.8" />
    <!-- System.Text.Json removed per framework policy -->
    <PackageReference Include="Newtonsoft.Json" Version="13.0.4" />
  </ItemGroup>
</Project>

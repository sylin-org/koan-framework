<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <KoanPackageKind>Periphery</KoanPackageKind>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <Description>Core orchestration logic for the Koan CLI: app discovery, manifest assembly, compose generation, and provider election. Shared with the CLI front-end (Koan.Orchestration.Cli) and consumable by tooling that builds on the same primitives.</Description>
    <PackageTags>$(CommonPackageTags);orchestration;cli;compose;docker;podman</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\Koan.Orchestration.Abstractions\Koan.Orchestration.Abstractions.csproj" />
    <ProjectReference Include="..\Koan.Orchestration.Generators\Koan.Orchestration.Generators.csproj" ReferenceOutputAssembly="false" OutputItemType="Analyzer" />
  <ProjectReference Include="..\Connectors\Orchestration\Renderers\Compose\Koan.Orchestration.Renderers.Connector.Compose.csproj" />
    <ProjectReference Include="..\Connectors\Orchestration\Docker\Koan.Orchestration.Connector.Docker.csproj" />
    <ProjectReference Include="..\Connectors\Orchestration\Podman\Koan.Orchestration.Connector.Podman.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Newtonsoft.Json" Version="13.0.4" />
    <PackageReference Include="System.Reflection.MetadataLoadContext" Version="10.0.0" />
  </ItemGroup>
</Project>

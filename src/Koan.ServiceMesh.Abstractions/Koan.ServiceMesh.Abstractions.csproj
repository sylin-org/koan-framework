<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <KoanPackageKind>Kernel</KoanPackageKind>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <Description>Service abstractions for Koan: attributes, contracts, and service mesh interfaces for composable capability services.</Description>
    <PackageTags>$(CommonPackageTags);services;abstractions;attributes;discovery</PackageTags>
  </PropertyGroup>
</Project>

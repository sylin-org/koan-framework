<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <KoanPackageKind>Periphery</KoanPackageKind>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <Description>Uri-inspired prompt primitive for Koan AI: parse, build, version, and A/B test prompts with entity-backed storage.</Description>
    <PackageTags>$(CommonPackageTags);ai;prompt</PackageTags>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\Koan.Core\Koan.Core.csproj" />
    <ProjectReference Include="..\Koan.Data.Core\Koan.Data.Core.csproj" />
    <ProjectReference Include="..\Koan.AI.Contracts\Koan.AI.Contracts.csproj" />
  </ItemGroup>
</Project>

<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <AssemblyName>Koan.Canon.Web</AssemblyName>
    <RootNamespace>Koan.Canon.Web</RootNamespace>
    <Description>Generated ASP.NET Core and inspection surfaces for discovered Koan Canon models.</Description>
    <PackageTags>$(CommonPackageTags);canon;web;controllers;runtime</PackageTags>
  </PropertyGroup>
  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\Koan.Canon\Koan.Canon.csproj" />
    <ProjectReference Include="..\Koan.Core\Koan.Core.csproj" />
    <ProjectReference Include="..\Koan.Web\Koan.Web.csproj" />
    <ProjectReference Include="..\Koan.Web.Extensions\Koan.Web.Extensions.csproj" />
  </ItemGroup>
</Project>

<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AssemblyName>Koan.Cache.Adapter.Redis</AssemblyName>
    <RootNamespace>Koan.Cache.Adapter.Redis</RootNamespace>
    <Description>Redis-backed Remote Cache and layered every-node invalidation, using Koan's shared Redis backend without activating Data.</Description>
    <PackageTags>$(CommonPackageTags);cache;adapter;redis;l2;coherence</PackageTags>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\Koan.Cache\Koan.Cache.csproj"
                      />
    <ProjectReference Include="..\Koan.Cache.Abstractions\Koan.Cache.Abstractions.csproj" />
    <ProjectReference Include="..\Koan.Communication\Koan.Communication.csproj"
                      />
    <ProjectReference Include="..\Koan.Redis.Abstractions\Koan.Redis.Abstractions.csproj" />
    <ProjectReference Include="..\Koan.Redis\Koan.Redis.csproj" />
    <PackageReference Include="Newtonsoft.Json" Version="13.0.4" />
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" Version="10.0.8" />
    <PackageReference Include="Microsoft.Extensions.Options" Version="10.0.8" />
    <PackageReference Include="StackExchange.Redis" Version="2.9.32" />
  </ItemGroup>
</Project>

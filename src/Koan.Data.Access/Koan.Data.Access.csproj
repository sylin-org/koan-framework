<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <KoanPackageKind>Periphery</KoanPackageKind>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <AssemblyName>Koan.Data.Access</AssemblyName>
    <RootNamespace>Koan.Data.Access</RootNamespace>
    <Description>Access scoping for Koan (SEC-0008): one module-owned logical-flow subject contributes an independent Core context carrier and Data read axis. [AccessScoped] opts an entity in; reads are narrowed to the current subject's matching scope tokens through a pushable row-visibility predicate and fail closed when the subject is absent. Jobs carries that context across durable hops without Data.Core naming subjects. Reference = Intent.</Description>
    <PackageTags>$(CommonPackageTags);access;authorization;row-visibility;ambient-subject</PackageTags>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\Koan.Core\Koan.Core.csproj" />
    <ProjectReference Include="..\Koan.Data.Abstractions\Koan.Data.Abstractions.csproj" />
    <ProjectReference Include="..\Koan.Data.Core\Koan.Data.Core.csproj" />
  </ItemGroup>
</Project>

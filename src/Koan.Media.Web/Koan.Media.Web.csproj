<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <KoanPackageKind>Periphery</KoanPackageKind>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <Description>Web layer for Koan Media: upload endpoints, variant routing, and storage-backed streaming helpers for media entities.</Description>
    <PackageTags>$(CommonPackageTags);media;web;storage;upload;variants</PackageTags>
  </PropertyGroup>
  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
    <ProjectReference Include="..\Koan.Media.Abstractions\Koan.Media.Abstractions.csproj" />
    <ProjectReference Include="..\Koan.Media.Core\Koan.Media.Core.csproj" />
    <ProjectReference Include="..\Koan.Storage\Koan.Storage.csproj" />
    <!-- M11: transform cache rides Koan.Cache (was IMemoryCache-backed) -->
    <ProjectReference Include="..\Koan.Cache\Koan.Cache.csproj" />
  </ItemGroup>
</Project>
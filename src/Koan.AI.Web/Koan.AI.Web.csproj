<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <Description>Provider-neutral HTTP projection for Koan AI chat, embeddings, model inventory, and capability inspection.</Description>
    <PackageTags>$(CommonPackageTags);web;aspnetcore;controllers;ai;chat;embeddings</PackageTags>
  </PropertyGroup>
  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>
  <ItemGroup>
    <Using Include="Koan.Core" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\Koan.AI\Koan.AI.csproj" />
    <ProjectReference Include="..\Koan.AI.Contracts\Koan.AI.Contracts.csproj" />
    <ProjectReference Include="..\Koan.Web\Koan.Web.csproj" />
    <ProjectReference Include="..\Koan.Web.Sse\Koan.Web.Sse.csproj" />
  </ItemGroup>
</Project>

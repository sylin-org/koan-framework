<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <Description>Koan AI facade and runtime glue.</Description>
    <PackageTags>$(CommonPackageTags);ai;facade;runtime</PackageTags>
    <Version>0.6.3</Version>
    <AssemblyVersion>0.6.3</AssemblyVersion>
    <FileVersion>0.6.3</FileVersion>
  </PropertyGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="Koan.AI.Integration.Tests" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\Koan.Core\Koan.Core.csproj" />
    <ProjectReference Include="..\Koan.AI.Contracts\Koan.AI.Contracts.csproj" />
    <ProjectReference Include="..\Koan.AI.Prompt\Koan.AI.Prompt.csproj" />
    <ProjectReference Include="..\Koan.Storage\Koan.Storage.csproj" />
    <ProjectReference Include="..\Koan.Media.Abstractions\Koan.Media.Abstractions.csproj" />
    <PackageReference Include="Microsoft.Extensions.AI" Version="10.0.0" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" Version="10.0.0" />
  </ItemGroup>
</Project>
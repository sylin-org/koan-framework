<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>

    <KoanPackageKind>Periphery</KoanPackageKind>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <Description>Strict JSON serialization configuration for Koan.Web — opt-in stricter defaults (no implicit type coercion, exact property names) for APIs that need contract-precise payloads.</Description>
    <PackageTags>$(CommonPackageTags);web;json;serialization;strict</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\Koan.Core\Koan.Core.csproj" />
  </ItemGroup>

  <ItemGroup>
    <AssemblyAttribute Include="System.Runtime.CompilerServices.InternalsVisibleTo">
      <_Parameter1>Koan.Web.Json.Strict.Tests</_Parameter1>
    </AssemblyAttribute>
  </ItemGroup>

</Project>

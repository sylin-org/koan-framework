<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>netstandard2.0</TargetFramework>
    <Nullable>enable</Nullable>
    <OutputType>Library</OutputType>
    <IncludeBuildOutput>false</IncludeBuildOutput>
    <AssemblyName>Koan.Orchestration.Generators</AssemblyName>
    <RootNamespace>Koan.Orchestration.Generators</RootNamespace>
    <!--
      Set to false because the generator still uses the legacy ISourceGenerator API. The
      Roslyn analyzer enforces RS1035/RS1042 against use of GeneratorExecutionContext when
      EnforceExtendedAnalyzerRules=true and promotes the diagnostics to errors regardless of
      NoWarn below. Porting to IIncrementalGenerator is a separate, larger upstream task
      (~550 lines of restructuring + testing the emitted output); until that lands, keep the
      enforcement off so consumers can pack the framework without -p:EnforceExtendedAnalyzerRules=false.
    -->
    <EnforceExtendedAnalyzerRules>false</EnforceExtendedAnalyzerRules>
    <Description>Source generator analyzers for Koan orchestration manifests, module metadata inspection, and diagnostics.</Description>
    <PackageTags>$(CommonPackageTags);analyzer;source-generator;orchestration</PackageTags>
    <IsPackable>true</IsPackable>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp" Version="4.14.0" PrivateAssets="all" />
    <PackageReference Include="Microsoft.CodeAnalysis.Analyzers" Version="3.11.0" PrivateAssets="all" />
  </ItemGroup>
  <!-- Analyzer release tracking files must be included as AdditionalFiles for RS2008 compliance -->
  <ItemGroup>
    <None Remove="AnalyzerReleases.Shipped.md;AnalyzerReleases.Unshipped.md" />
  </ItemGroup>
  <ItemGroup>
    <AdditionalFiles Include="AnalyzerReleases.Shipped.md" />
    <AdditionalFiles Include="AnalyzerReleases.Unshipped.md" />
  </ItemGroup>
  <ItemGroup>
    <None Include="$(OutputPath)$(AssemblyName).dll" Pack="true" PackagePath="analyzers/dotnet/cs" Visible="false" />
    <None Include="$(OutputPath)$(AssemblyName).xml" Pack="true" PackagePath="analyzers/dotnet/cs" Visible="false" Condition="Exists('$(OutputPath)$(AssemblyName).xml')" />
  </ItemGroup>
  <PropertyGroup>
    <!-- Mark this assembly as an analyzer for consumers -->
    <IsRoslynComponent>true</IsRoslynComponent>
    <!-- See Koan.Cache.Analyzers.csproj for the rationale on these symbol/pack settings. -->
    <IncludeSymbols>false</IncludeSymbols>
    <IncludeSource>false</IncludeSource>
    <NoWarn>$(NoWarn);RS2007;RS1035;RS1042;NU5017;NU5019;NU5128</NoWarn>
  </PropertyGroup>
</Project>

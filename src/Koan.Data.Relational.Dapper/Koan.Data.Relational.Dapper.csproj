<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <KoanPackageKind>Periphery</KoanPackageKind>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <Description>Dapper-backed implementation of the Koan relational command helpers (SqlParameters/AdoCommands surface) for non-AOT relational adapters. AOT-targeted adapters use the hand-rolled Koan.Data.Relational.Ado helpers instead, since Dapper emits IL at runtime.</Description>
    <PackageTags>$(CommonPackageTags);data;relational;dapper;sql</PackageTags>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Dapper" Version="2.1.66" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\Koan.Data.Relational\Koan.Data.Relational.csproj" />
  </ItemGroup>
</Project>

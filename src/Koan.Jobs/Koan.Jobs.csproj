<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <Description>Run Entity-owned background work with inspectable progress, retries, cancellation, schedules, and capability-graded durability through AddKoan().</Description>
    <PackageTags>$(CommonPackageTags);jobs;orchestrator;ledger;scheduling;background</PackageTags>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\Koan.Core\Koan.Core.csproj" />
    <ProjectReference Include="..\Koan.Communication\Koan.Communication.csproj"
                      />
    <ProjectReference Include="..\Koan.Data.Abstractions\Koan.Data.Abstractions.csproj" />
    <ProjectReference Include="..\Koan.Data.Core\Koan.Data.Core.csproj" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Cronos" Version="0.13.0" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" Version="10.0.8" />
    <PackageReference Include="Microsoft.Extensions.Hosting.Abstractions" Version="10.0.8" />
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" Version="10.0.8" />
    <PackageReference Include="Microsoft.Extensions.Options" Version="10.0.8" />
  </ItemGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="Koan.Jobs.Tests" />
    <InternalsVisibleTo Include="Koan.Jobs.TestKit" />
    <InternalsVisibleTo Include="Koan.Jobs.Adapter.Sqlite.Tests" />
    <InternalsVisibleTo Include="Koan.Tests.Integration.Bootstrap.Pillars" />
    <InternalsVisibleTo Include="Koan.Samples.SnapVault.Tests" />
  </ItemGroup>
</Project>

<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <OutputType>Exe</OutputType>
    <RootNamespace>AnimeRecommendations</RootNamespace>
    <RunWorkingDirectory>$(MSBuildProjectDirectory)</RunWorkingDirectory>
  </PropertyGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\..\src\Koan.Web\Koan.Web.csproj" />
    <ProjectReference Include="..\..\..\src\Koan.Web.OpenApi\Koan.Web.OpenApi.csproj" />
    <ProjectReference Include="..\..\..\src\Connectors\Data\Sqlite\Koan.Data.Connector.Sqlite.csproj" />
    <ProjectReference Include="..\..\..\src\Koan.Data.AI\Koan.Data.AI.csproj" />
    <ProjectReference Include="..\..\..\src\Connectors\Data\Vector\SqliteVec\Koan.Data.Vector.Connector.SqliteVec.csproj" />
    <ProjectReference Include="..\..\..\src\Connectors\AI\Onnx\Koan.AI.Connector.Onnx.csproj" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="..\..\..\assets\models\all-MiniLM-L6-v2\model_quantized.onnx"
             Link="models\model_quantized.onnx"
             CopyToOutputDirectory="PreserveNewest"
             CopyToPublishDirectory="PreserveNewest" />
    <Content Include="..\..\..\assets\models\all-MiniLM-L6-v2\vocab.txt"
             Link="models\vocab.txt"
             CopyToOutputDirectory="PreserveNewest"
             CopyToPublishDirectory="PreserveNewest" />
  </ItemGroup>
</Project>

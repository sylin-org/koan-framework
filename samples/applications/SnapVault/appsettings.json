{
  "Koan": {
    "Data": {
      "Sources": {
        "Default": {
          "Adapter": "sqlite",
          "ConnectionString": "Data Source=.koan/snapvault.db"
        }
      }
    },
    "Storage": {
      "DefaultProfile": "cold",
      "Providers": {
        "Local": {
          "BasePath": ".koan/storage"
        }
      },
      "Profiles": {
        "cold": {
          "Provider": "local",
          "Container": "photos"
        }
      }
    }
  },
  "SnapVault": {
    "Collections": {
      "MaxPhotosPerCollection": 2048
    }
  }
}

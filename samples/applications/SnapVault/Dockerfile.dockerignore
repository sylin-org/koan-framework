# Build outputs
**/bin/
**/obj/
**/packages/
**/.nuget/
**/TestResults/
**/BenchmarkDotNet.Artifacts/
**/artifacts/

# Git
.git/
.gitignore
.gitattributes

# IDE
.vs/
.vscode/
**/*.user
**/*.suo
**/*.userosscache
**/*.sln.docstates

# Documentation (not needed for runtime)
**/*.md
!**/AnalyzerReleases.Shipped.md
!**/AnalyzerReleases.Unshipped.md

# Tests (not needed for sample builds)
**/Tests/
**/tests/
**/*.Tests/
**/*.Test/

# Node
**/node_modules/

# Docker
**/Dockerfile
**/.dockerignore
**/docker-compose*.yml

# All .Koan directories (volume data, cache, storage)
**/.Koan/

# Logs
**/logs/
**/*.log

# Database files
**/*.db
**/*.db-shm
**/*.db-wal

# OS
**/.DS_Store
**/Thumbs.db

# Temporary files
**/tmp/
**/temp/

# Other samples are not needed for this build (context is repo root).
samples/**
!samples/Directory.Build.props
!samples/applications/
!samples/applications/SnapVault/
!samples/applications/SnapVault/**

# Claude / tools
.claude/
tools/
scripts/
packaging/
other/
data/
resources/
docs/
.github/

{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Koan": {
    "Web": {
      "OpenGraph": {
        "ShellPath": "wwwroot/index.html",
        "SiteName": "Koan Developer Publishing Portal",
        "DefaultDescription": "Approve articles locally and publish them through named provider channels."
      }
    },
    "Data": {
      "Sources": {
        "Default": {
          "Adapter": "sqlite",
          "ConnectionString": "Data Source=.koan/editorial.db"
        },
        "Preview": {
          "Adapter": "sqlite",
          "ConnectionString": "Data Source=.koan/preview.db"
        },
        "Documents": {
          "Adapter": "mongo",
          "ConnectionString": "mongodb://localhost:5091/DevPortalDocuments"
        },
        "Relational": {
          "Adapter": "postgres",
          "ConnectionString": "Host=localhost;Port=5092;Database=devportal;Username=postgres;Password=dev"
        }
      }
    }
  }
}

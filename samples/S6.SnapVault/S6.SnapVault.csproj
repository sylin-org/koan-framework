<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>S6.SnapVault</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <!-- Koan Framework - Core -->
    <ProjectReference Include="..\..\src\Koan.Core\Koan.Core.csproj" />
    <ProjectReference Include="..\..\src\Koan.Data.Core\Koan.Data.Core.csproj" />
    <ProjectReference Include="..\..\src\Koan.Web\Koan.Web.csproj" />
    <ProjectReference Include="..\..\src\Koan.Web.Extensions\Koan.Web.Extensions.csproj" />
    <!-- Server-Sent Events (D4): upload progress is streamed as SSE — a read-projection of the durable jobs
         ledger — replacing the old SignalR PhotoProcessingHub (no hub, no groups, no client library). -->
    <ProjectReference Include="..\..\src\Koan.Web.Sse\Koan.Web.Sse.csproj" />

    <!-- Multi-tenancy (Reference = Intent): every non-[HostScoped] Entity<T> auto-isolates by the
         ambient tenant across data, blob storage, cache, and the async-hop. SnapVault Phase 1. -->
    <ProjectReference Include="..\..\src\Koan.Tenancy\Koan.Tenancy.csproj" />

    <!-- Durable, tenant-carrying background jobs (replaces the in-memory queue + PhotoProcessingWorker). -->
    <ProjectReference Include="..\..\src\Koan.Jobs\Koan.Jobs.csproj" />

    <!-- Data Providers -->
    <ProjectReference Include="..\..\src\Connectors\Data\Mongo\Koan.Data.Connector.Mongo.csproj" />

    <!-- Media Processing. Koan.Media.Web brings the recipe controller (GET /media/{id}/{recipe}) +
         MediaEntitySource<T> — on-demand transforms served from the single stored original, access-scoped. -->
    <ProjectReference Include="..\..\src\Koan.Media.Core\Koan.Media.Core.csproj" />
    <ProjectReference Include="..\..\src\Koan.Media.Abstractions\Koan.Media.Abstractions.csproj" />
    <ProjectReference Include="..\..\src\Koan.Media.Web\Koan.Media.Web.csproj" />

    <!-- Storage -->
    <ProjectReference Include="..\..\src\Koan.Storage\Koan.Storage.csproj" />
    <ProjectReference Include="..\..\src\Connectors\Storage\Local\Koan.Storage.Connector.Local.csproj" />
    <ProjectReference Include="..\..\src\Connectors\Storage\S3\Koan.Storage.Connector.S3.csproj" />

    <!-- AI -->
    <ProjectReference Include="..\..\src\Koan.AI\Koan.AI.csproj" />
    <ProjectReference Include="..\..\src\Koan.Data.AI\Koan.Data.AI.csproj" />
    <ProjectReference Include="..\..\src\Connectors\AI\Ollama\Koan.AI.Connector.Ollama.csproj" />
    <ProjectReference Include="..\..\src\Koan.ZenGarden\Koan.ZenGarden.csproj" />

    <!-- Vector Search -->
    <ProjectReference Include="..\..\src\Koan.Data.Vector\Koan.Data.Vector.csproj" />
    <ProjectReference Include="..\..\src\Koan.Data.Vector.Abstractions\Koan.Data.Vector.Abstractions.csproj" />
    <ProjectReference Include="..\..\src\Connectors\Data\Vector\Weaviate\Koan.Data.Vector.Connector.Weaviate.csproj" />
  </ItemGroup>

  <ItemGroup>
    <!-- Studio↔client lifecycle (SEC-0007 P5 dogfood). Reference = Intent: AddKoan() discovers these. -->
    <!-- Durable PERSON keystone: Identity + verified IdentityEmail factors + reconciler + auth-flow handler. -->
    <ProjectReference Include="..\..\src\Koan.Identity\Koan.Identity.csproj" />
    <!-- Invite-binds-to-identity + tenant-resolution middleware + atomic deprovisioning + tamper-evident receipt. -->
    <ProjectReference Include="..\..\src\Koan.Identity.Tenancy\Koan.Identity.Tenancy.csproj" />
    <!-- External sign-in: cookie auth + provider discovery + the SEC-0004 capability-authz floor. -->
    <ProjectReference Include="..\..\src\Koan.Web.Auth\Koan.Web.Auth.csproj" />
    <!-- Dev zero-config sign-in provider (asserts a verified email; Development only). -->
    <ProjectReference Include="..\..\src\Connectors\Web\Auth\Test\Koan.Web.Auth.Connector.Test.csproj" />
    <!-- Production OAuth — verified email via Google's email_verified claim. -->
    <ProjectReference Include="..\..\src\Connectors\Web\Auth\Google\Koan.Web.Auth.Connector.Google.csproj" />
    <!-- Data-layer access scoping (SEC-0008): [AccessScoped] narrows a guest's PhotoAsset reads to their granted
         events via the ambient Subject — inherently, in services/jobs/SSE, not just controllers. -->
    <ProjectReference Include="..\..\src\Koan.Data.Access\Koan.Data.Access.csproj" />
  </ItemGroup>

  <ItemGroup>
    <!-- Image Processing Library. Pinned to the same ImageSharp line Koan.Media.Core builds against
         (3.1.x / Drawing 2.1.x); a sample must not force a higher major onto the framework's media stack.
         EXIF is read via ImageSharp's ExifProfile, and SignalR server APIs come from Microsoft.AspNetCore.App —
         so the former MetadataExtractor and Microsoft.AspNetCore.SignalR.Client refs were unused and removed. -->
    <PackageReference Include="SixLabors.ImageSharp" Version="3.1.12" />
    <PackageReference Include="SixLabors.ImageSharp.Drawing" Version="2.1.6" />
  </ItemGroup>

  <ItemGroup>
    <!-- _legacy/ holds value-bearing port-source not yet rebuilt (ported in steps 2-6, deleted at step 7).
         Excluded from compile + content so step 1 reduces to the kept core. Microsoft.NET.Sdk.Web globs
         **/*.cs as Compile and **/* as content, so remove from both. -->
    <Compile Remove="_legacy\**\*.cs" />
    <Content Remove="_legacy\**\*" />
    <None Remove="_legacy\**\*" />
    <EmbeddedResource Remove="_legacy\**\*" />
  </ItemGroup>

</Project>

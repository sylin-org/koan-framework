{
  "Koan": {
    "Data": {
      "Mongo": {
        "Database": "SnapVault"
      }
    },
    "Storage": {
      "DefaultProfile": "cold",
      "Providers": {
        "Local": {
          "BasePath": "./storage"
        }
      },
      "Profiles": {
        "cold": {
          "Container": "photos"
        }
      }
    }
  },
  "SnapVault": {
    "Collections": {
      "MaxPhotosPerCollection": 2048
    }
  }
}

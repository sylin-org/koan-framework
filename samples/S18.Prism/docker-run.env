# Prism Container Environment
# Used by standalone docker run (without compose).
# Infrastructure services must be reachable via host.docker.internal.

ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:5087

Koan__Data__Mongo__ConnectionString=mongodb://host.docker.internal:27017
Koan__Data__Mongo__Database=Prism
Koan__Storage__Providers__Local__BasePath=/app/storage
OLLAMA_HOST=http://host.docker.internal:11434

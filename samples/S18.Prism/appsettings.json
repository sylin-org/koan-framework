{
  "Koan": {
    "Data": {
      "Mongo": {
        "Database": "Prism"
      }
    },
    "Storage": {
      "DefaultProfile": "standard",
      "Providers": {
        "Local": {
          "BasePath": "./storage"
        }
      },
      "Profiles": {
        "standard": {
          "Container": "knowledge",
          "Mode": "local"
        }
      }
    }
  },
  "Prism": {
    "DefaultSpaces": [
      { "Name": "Personal", "Description": "Your private knowledge base" }
    ],
    "ModelCrawler": {
      "Enabled": true,
      "Schedule": "Daily",
      "SeedCategories": [
        "text-generation",
        "text2text-generation",
        "feature-extraction",
        "image-classification",
        "automatic-speech-recognition"
      ]
    }
  }
}

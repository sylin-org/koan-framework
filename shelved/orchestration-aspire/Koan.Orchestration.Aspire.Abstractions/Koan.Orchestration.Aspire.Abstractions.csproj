<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <Description>Shelved contract for the adjacent automatic Aspire AppHost contributor experiment.</Description>
    <PackageTags>$(CommonPackageTags);shelved;aspire;experiment;contracts</PackageTags>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Aspire.Hosting" Version="13.0.0" />
    <PackageReference Include="Microsoft.Extensions.Configuration.Abstractions" Version="10.0.8" />
    <PackageReference Include="Microsoft.Extensions.Hosting.Abstractions" Version="10.0.8" />
    <!-- Shared floor for Aspire.Hosting 13.0.0's MessagePack dependency (CVE-2026-48109). -->
    <PackageReference Include="MessagePack" Version="2.5.301" />
  </ItemGroup>
</Project>

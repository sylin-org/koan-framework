<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>Koan.Orchestration.Cli</RootNamespace>
    <Description>Koan development-host CLI: discover application services, compile plans, render Compose bundles, and execute provider workflows.</Description>
    <PackageTags>$(CommonPackageTags);cli;orchestration;compose;devhost</PackageTags>
    <PackAsTool>true</PackAsTool>
    <ToolCommandName>koan-orchestrate</ToolCommandName>
    <IsPackable>true</IsPackable>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\Koan.Orchestration.Abstractions\Koan.Orchestration.Abstractions.csproj" />
    <ProjectReference Include="..\Koan.Orchestration.Generators\Koan.Orchestration.Generators.csproj" ReferenceOutputAssembly="false" OutputItemType="Analyzer" />
    <ProjectReference Include="..\Koan.Orchestration.Renderers.Connector.Compose\Koan.Orchestration.Renderers.Connector.Compose.csproj" />
    <ProjectReference Include="..\Koan.Orchestration.Connector.Docker\Koan.Orchestration.Connector.Docker.csproj" />
    <ProjectReference Include="..\Koan.Orchestration.Connector.Podman\Koan.Orchestration.Connector.Podman.csproj" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="System.Reflection.MetadataLoadContext" Version="10.0.8" />
    <PackageReference Include="Newtonsoft.Json" Version="13.0.4" />
  </ItemGroup>
</Project>

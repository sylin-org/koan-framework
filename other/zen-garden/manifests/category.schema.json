{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://zen-garden.dev/schemas/category.schema.json",
  "title": "Category Configuration",
  "description": "Configuration for a manifest category folder",
  "type": "object",
  "required": ["name", "description"],
  "properties": {
    "name": {
      "type": "string",
      "description": "Canonical category name (matches folder name)"
    },
    "description": {
      "type": "string",
      "description": "Human-readable category description"
    },
    "aliases": {
      "type": "array",
      "description": "Token aliases that resolve to this category",
      "items": { "type": "string" },
      "default": []
    },
    "parent_of": {
      "type": "array",
      "description": "Categories this category encompasses (e.g., 'database' includes 'cache', 'search')",
      "items": { "type": "string" },
      "default": []
    },
    "default_protocol": {
      "type": "string",
      "description": "Default connection protocol for services in this category"
    },
    "connection_template": {
      "type": "string",
      "description": "Default connection URI template (uses {host}, {port}, {protocol} placeholders)"
    },
    "tags": {
      "type": "array",
      "description": "Default tags applied to all offerings in this category",
      "items": { "type": "string" },
      "default": []
    }
  },
  "additionalProperties": false
}

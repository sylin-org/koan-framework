# Garden-Moss Daemon Configuration File
# 
# This file configures the Zen Garden Garden-Moss daemon.
# Configuration priority: CLI arguments > Environment variables > Config file > Defaults
#
# File locations:
# - Linux: /etc/zen-garden/garden-moss.toml
# - Windows: ./garden-moss.toml (current directory)
#
# To use this file:
# - Linux: sudo cp moss.toml.example /etc/zen-garden/garden-moss.toml
# - Windows: copy moss.toml.example garden-moss.toml
#
# All fields are optional. Uncomment and modify as needed.

# Stone name identifier
# Default: "stone-01"
# Can be overridden by: --stone-name CLI arg or STONE_NAME environment variable
#stone_name = "stone-01"

# HTTP server port
# Default: 3001
# Can be overridden by: --port CLI arg or PORT environment variable
#port = 3001

# Log level: trace, debug, info, warn, error
# Default: "info"
# Can be overridden by: --log-level CLI arg or RUST_LOG environment variable
#log_level = "info"

# Example production configuration:
# stone_name = "prod-stone-east-01"
# port = 3001
# log_level = "warn"

# Example development configuration:
# stone_name = "dev-stone-local"
# port = 3002
# log_level = "debug"

# Moss Daemon Configuration File
#
# This file provides default configuration values for the Moss daemon.
# Configuration priority order: CLI arguments > Environment variables > Config file > Defaults
#
# Linux installation path: /etc/zen-garden/moss.toml
# Windows fallback path: ./moss.toml (current directory)

# Stone identifier (unique name for this node)
# Can be overridden by: --stone-name CLI arg or STONE_NAME env var
# Default: "stone-01"
stone_name = "stone-01"

# HTTP server port for Moss API
# Can be overridden by: --port CLI arg or PORT env var
# Default: 3001
port = 3001

# Logging verbosity level
# Valid values: "trace", "debug", "info", "warn", "error"
# Can be overridden by: --log-level CLI arg or RUST_LOG env var
# Default: "info"
log_level = "info"

# Fast sync timeout in seconds for rapid offering deployments
# When set, enables optimized deployment mode with reduced polling intervals
# Can be overridden by: --fast-sync-timeout CLI arg or FAST_SYNC_TIMEOUT env var
# Default: disabled (comment out or omit to disable)
# fast_sync_timeout = 5

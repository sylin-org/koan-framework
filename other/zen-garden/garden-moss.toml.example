# Zen Garden - Moss Configuration Example
# Copy this to:
#   Linux: /etc/zen-garden/garden-moss.toml
#   Windows: ./garden-moss.toml (current directory)

# ============================================================================
# Core Settings
# ============================================================================

# Stone identifier (default: "stone-01")
# stone_name = "stone-crimson-summit"

# HTTP API port (default: 7185)
# port = 7185

# Log level: trace, debug, info, warn, error (default: "info")
# log_level = "info"

# Console output mode: silent, minimal, informative, verbose
# Default: platform-specific (minimal for systemd, informative for interactive)
# console_mode = "informative"

# ============================================================================
# Performance & Timing Tunables
# ============================================================================

# Event deduplication TTL in seconds (default: 10)
# Prevents high-frequency events (like Docker pulls) from spamming console
# event_dedup_ttl_secs = 10

# Docker connection retry delay in seconds (default: 3)
# How long to wait between Docker daemon connection attempts
# docker_retry_delay_secs = 3

# Health check interval in seconds (default: 30)
# How often background health monitoring runs
# health_check_interval_secs = 30

# Docker reconnect interval in seconds (default: 5)
# How often to retry Docker connection when disconnected
# docker_reconnect_interval_secs = 5

# ============================================================================
# HTTP Client Timeouts
# ============================================================================

# Capabilities fetch timeout in seconds (default: 5)
# Timeout for fetching stone hardware capabilities
# http_capabilities_timeout_secs = 5

# Health check timeout in seconds (default: 2)
# Timeout for regular health check requests
# http_health_timeout_secs = 2

# Quick health check timeout in milliseconds (default: 200)
# Timeout for fast/probe health checks
# http_quick_health_timeout_millis = 200

# Long operation timeout in seconds (default: 300)
# Timeout for lengthy operations like image pulls, service upgrades
# http_long_operation_timeout_secs = 300

# ============================================================================
# Advanced Settings
# ============================================================================

# Fast sync timeout in seconds (default: disabled)
# Enables rapid offering deployment mode for testing/development
# WARNING: Bypasses safety checks - use only in controlled environments
# fast_sync_timeout = 60

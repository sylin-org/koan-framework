<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <IsPackable>false</IsPackable>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <!-- ARCH-0091: xUnit v3 self-executing test assembly. The factory boots a TestServer host directly
         (no WebApplicationFactory/Program), so xUnit owns the entry point and we use the plain SDK. -->
    <OutputType>Exe</OutputType>
    <NoWarn>$(NoWarn);NU1902;NU1903</NoWarn>
    <WarningsNotAsErrors>$(WarningsNotAsErrors);NU1902;NU1903</WarningsNotAsErrors>
  </PropertyGroup>
  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\Koan.Web.AdapterSurface.TestKit\Koan.Web.AdapterSurface.TestKit.csproj" />
    <ProjectReference Include="..\..\..\..\..\src\Connectors\Data\Redis\Koan.Data.Connector.Redis.csproj" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.TestHost" />
    <PackageReference Include="Microsoft.NET.Test.Sdk" />
    <PackageReference Include="xunit.v3" />
    <PackageReference Include="xunit.runner.visualstudio">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
  </ItemGroup>
</Project>

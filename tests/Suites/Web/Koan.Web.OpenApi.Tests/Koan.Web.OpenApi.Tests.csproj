<Project Sdk="Microsoft.NET.Sdk.Web">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <IsPackable>false</IsPackable>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <!-- Pre-existing vulnerability warnings in transitive deps. -->
    <NoWarn>$(NoWarn);NU1902;NU1903</NoWarn>
    <WarningsNotAsErrors>$(WarningsNotAsErrors);NU1902;NU1903</WarningsNotAsErrors>
    <!-- SDK.Web top-level Program + Microsoft.NET.Test.Sdk's generated Main both qualify as entry
         points (CS7022). Tests run via the VSTest adapter, not the assembly Main, so the duplicate is
         harmless — keep the top-level Program (WebApplicationFactory<Program>) and drop the SDK's Main. -->
    <GenerateProgramFile>false</GenerateProgramFile>
  </PropertyGroup>

  <ItemGroup>
    <!-- WebApplicationFactory's content-root probe walks bin/Debug/net10.0/ upward for any *.sln file.
         tests/Directory.Build.props relocates outputs to %TEMP%, where no .sln exists. We materialize
         a marker .sln in the bin output to satisfy the probe; it is functionally empty. -->
    <None Include="$(MSBuildThisFileDirectory)Koan.WebOpenApiTests.MarkerSolution.sln" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\..\..\src\Koan.Core\Koan.Core.csproj" />
    <ProjectReference Include="..\..\..\..\src\Koan.Data.Abstractions\Koan.Data.Abstractions.csproj" />
    <ProjectReference Include="..\..\..\..\src\Koan.Data.Core\Koan.Data.Core.csproj" />
    <ProjectReference Include="..\..\..\..\src\Koan.Web\Koan.Web.csproj" />
    <ProjectReference Include="..\..\..\..\src\Koan.Web.OpenApi\Koan.Web.OpenApi.csproj" />
    <ProjectReference Include="..\..\..\..\src\Connectors\Data\InMemory\Koan.Data.Connector.InMemory.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="AwesomeAssertions" Version="9.4.0" />
    <PackageReference Include="Microsoft.AspNetCore.Mvc.Testing" Version="10.0.8" />
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="18.6.0" />
    <PackageReference Include="xunit" Version="2.9.3" />
    <PackageReference Include="xunit.runner.visualstudio" Version="3.1.5">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
  </ItemGroup>
</Project>

      <PrivateAssets>all</PrivateAssets>
    </PackageReference>
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\..\..\src\Koan.Security.Trust\Koan.Security.Trust.csproj" />
  </ItemGroup>


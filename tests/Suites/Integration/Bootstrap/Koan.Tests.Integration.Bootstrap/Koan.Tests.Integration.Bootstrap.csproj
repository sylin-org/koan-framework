<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <IsPackable>false</IsPackable>
    <!-- ARCH-0091: xUnit v3 runs as a self-executing test assembly (VSTest-compatible mode keeps `dotnet test`). -->
    <OutputType>Exe</OutputType>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="AwesomeAssertions" Version="9.4.0" />
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="18.6.0" />
    <PackageReference Include="xunit.v3" Version="3.2.2" />
    <PackageReference Include="xunit.runner.visualstudio" Version="3.1.5">
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
      <PrivateAssets>all</PrivateAssets>
    </PackageReference>
  </ItemGroup>

  <ItemGroup>
    <!-- ARCH-0091: KoanIntegrationHost (xUnit-free host) + the v3 RedisFixture (CachePillarBootstrapSpec).
         The bespoke Koan.Testing reference is dropped; its transitive graph is restored per-need. -->
    <ProjectReference Include="..\..\..\..\..\src\Koan.Testing.Hosting\Koan.Testing.Hosting.csproj" />
    <ProjectReference Include="..\..\..\..\..\src\Koan.Testing.Containers\Koan.Testing.Containers.csproj" />
    <ProjectReference Include="..\..\..\..\..\src\Koan.Core\Koan.Core.csproj" />

    <!-- Cache pillar (CachePillarBootstrapSpec) -->
    <ProjectReference Include="..\..\..\..\..\src\Koan.Cache\Koan.Cache.csproj" />
    <ProjectReference Include="..\..\..\..\..\src\Koan.Cache.Abstractions\Koan.Cache.Abstractions.csproj" />
    <ProjectReference Include="..\..\..\..\..\src\Koan.Cache.Adapter.Sqlite\Koan.Cache.Adapter.Sqlite.csproj" />
    <ProjectReference Include="..\..\..\..\..\src\Koan.Cache.Adapter.Redis\Koan.Cache.Adapter.Redis.csproj" />
    <ProjectReference Include="..\..\..\..\..\src\Koan.Cache.Coherence.InMemory\Koan.Cache.Coherence.InMemory.csproj" />

    <!-- Data pillar (DataCorePillarBootstrapSpec) — uses InMemory connector -->
    <ProjectReference Include="..\..\..\..\..\src\Koan.Data.Core\Koan.Data.Core.csproj" />
    <ProjectReference Include="..\..\..\..\..\src\Connectors\Data\InMemory\Koan.Data.Connector.InMemory.csproj" />

    <!-- Storage pillar (StoragePillarBootstrapSpec) — uses Local connector -->
    <ProjectReference Include="..\..\..\..\..\src\Koan.Storage\Koan.Storage.csproj" />
    <ProjectReference Include="..\..\..\..\..\src\Connectors\Storage\Local\Koan.Storage.Connector.Local.csproj" />

    <!-- Messaging pillar (MessagingCorePillarBootstrapSpec) — in-process provider -->
    <ProjectReference Include="..\..\..\..\..\src\Koan.Messaging.Core\Koan.Messaging.Core.csproj" />

    <!-- Auth pillar (AuthPillarBootstrapSpec) -->
    <ProjectReference Include="..\..\..\..\..\src\Koan.Web.Auth\Koan.Web.Auth.csproj" />

    <!-- AI pillar (AiPillarBootstrapSpec) -->
    <ProjectReference Include="..\..\..\..\..\src\Koan.AI\Koan.AI.csproj" />

    <!-- Web pillar (WebPillarBootstrapSpec) -->
    <ProjectReference Include="..\..\..\..\..\src\Koan.Web\Koan.Web.csproj" />

    <!-- Mcp pillar (McpPillarBootstrapSpec) -->
    <ProjectReference Include="..\..\..\..\..\src\Koan.Mcp\Koan.Mcp.csproj" />

    <!-- Media pillar (MediaPillarBootstrapSpec) -->
    <ProjectReference Include="..\..\..\..\..\src\Koan.Media.Core\Koan.Media.Core.csproj" />

    <!-- Jobs pillar (JobsPillarBootstrapSpec) -->
    <ProjectReference Include="..\..\..\..\..\src\Koan.Jobs\Koan.Jobs.csproj" />

    <!-- Canon pillar (CanonPillarBootstrapSpec) — Canon Web registrar is the only entry point -->
    <ProjectReference Include="..\..\..\..\..\src\Koan.Canon.Web\Koan.Canon.Web.csproj" />
  </ItemGroup>
</Project>

<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <OutputType>Exe</OutputType>
    <IsPackable>false</IsPackable>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>Koan.Mcp.Streamable.IntegrationTests</RootNamespace>
    <NoWarn>$(NoWarn);NU1902</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="AwesomeAssertions" />
    <PackageReference Include="Microsoft.NET.Test.Sdk" />
    <PackageReference Include="xunit.v3" />
    <PackageReference Include="xunit.runner.visualstudio">
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
      <PrivateAssets>all</PrivateAssets>
    </PackageReference>
    <PackageReference Include="coverlet.collector" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\..\..\src\Koan.Web\Koan.Web.csproj" />
    <ProjectReference Include="..\..\..\..\src\Koan.Web.Auth\Koan.Web.Auth.csproj" />
    <ProjectReference Include="..\..\..\..\src\Koan.Web.Auth.Server\Koan.Web.Auth.Server.csproj" />
    <ProjectReference Include="..\..\..\..\src\Koan.Mcp\Koan.Mcp.csproj" />
    <ProjectReference Include="..\..\..\..\src\Koan.Mcp.Explorer\Koan.Mcp.Explorer.csproj" />
    <ProjectReference Include="..\..\..\..\src\Koan.Security.Trust\Koan.Security.Trust.csproj" />
    <ProjectReference Include="..\..\..\..\src\Koan.Data.Core\Koan.Data.Core.csproj" />
    <ProjectReference Include="..\..\..\..\src\Connectors\Data\InMemory\Koan.Data.Connector.InMemory.csproj" />
  </ItemGroup>

</Project>

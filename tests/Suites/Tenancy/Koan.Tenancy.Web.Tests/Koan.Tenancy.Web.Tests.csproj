<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <IsPackable>false</IsPackable>
    <!-- ARCH-0091: xUnit v3 self-executing test assembly (VSTest-compatible mode keeps `dotnet test`). -->
    <OutputType>Exe</OutputType>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="AwesomeAssertions" Version="9.4.0" />
    <PackageReference Include="Microsoft.Extensions.Options.ConfigurationExtensions" Version="10.0.8" />
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="18.6.0" />
    <PackageReference Include="xunit.v3" Version="3.2.2" />
    <PackageReference Include="xunit.runner.visualstudio" Version="3.1.5">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
    <PackageReference Include="coverlet.collector" Version="6.0.4">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
  </ItemGroup>

  <ItemGroup>
    <!-- ARCH-0104: the console tests boot ONLY in "Test" env (the Koan.Web MVC service graph cannot pass a generic
         host's Development-env ValidateOnBuild — it needs IWebHostEnvironment), so they live in their own project
         rather than the core Koan.Tenancy.Tests suite (which must boot Development to exercise the dev-open posture). -->
    <ProjectReference Include="..\..\..\..\src\Koan.Testing.Hosting\Koan.Testing.Hosting.csproj" />
    <ProjectReference Include="..\..\..\..\src\Koan.Core\Koan.Core.csproj" />
    <ProjectReference Include="..\..\..\..\src\Koan.Data.Core\Koan.Data.Core.csproj" />
    <ProjectReference Include="..\..\..\..\src\Koan.Data.Abstractions\Koan.Data.Abstractions.csproj" />
    <ProjectReference Include="..\..\..\..\src\Koan.Tenancy\Koan.Tenancy.csproj" />
    <ProjectReference Include="..\..\..\..\src\Koan.Tenancy.Web\Koan.Tenancy.Web.csproj" />
    <ProjectReference Include="..\..\..\..\src\Connectors\Data\Sqlite\Koan.Data.Connector.Sqlite.csproj" />
  </ItemGroup>
</Project>

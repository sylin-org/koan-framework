<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <IsPackable>false</IsPackable>
    <RootNamespace>Koan.Jobs.Core.Tests</RootNamespace>
    <LangVersion>preview</LangVersion>
    <Nullable>enable</Nullable>
    <!-- Transitive OpenTelemetry advisories trip the test-suite TreatWarningsAsErrors policy.
         Same suppression other Koan test projects apply. -->
    <NoWarn>$(NoWarn);NU1902;NU1903</NoWarn>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="AwesomeAssertions" Version="9.4.0" />
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="18.6.0" />
    <PackageReference Include="xunit" Version="2.9.3" />
    <PackageReference Include="xunit.runner.visualstudio" Version="2.8.0" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\..\..\src\Koan.Core\Koan.Core.csproj" />
    <ProjectReference Include="..\..\..\..\src\Koan.Jobs.Core\Koan.Jobs.Core.csproj" />
  </ItemGroup>
  <!-- Exclude scaffold tests that depend on Koan.TestPipeline (not yet available) -->
  <ItemGroup>
    <Compile Remove="Support\JobsCoreTestPipelineFixture.cs" />
    <Compile Remove="Specs\CronParsingSpec.cs" />
    <Compile Remove="Specs\RetryBackoffSpec.cs" />
    <Compile Remove="Specs\SchedulerSpec.cs" />
    <Compile Remove="Specs\OrchestratedExecutionSpec.cs" />
    <Compile Remove="Specs\WorkerLifecycleSpec.cs" />
  </ItemGroup>
</Project>
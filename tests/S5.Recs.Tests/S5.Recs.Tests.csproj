<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <IsPackable>false</IsPackable>
    <OutputType>Exe</OutputType>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="18.6.0" />
    <PackageReference Include="xunit.v3" Version="3.2.2" />
    <PackageReference Include="xunit.runner.visualstudio" Version="3.1.5">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
  </ItemGroup>
  <ItemGroup>
    <!-- P2.1 dogfood: the sample supplies the entity (UserDoc); the kit supplies the suite. The InMemory
         adapter lets the conformance run without S5.Recs's Mongo container (forced via Configure). -->
    <ProjectReference Include="..\..\samples\S5.Recs\S5.Recs.csproj" />
    <ProjectReference Include="..\..\src\Koan.Testing\Koan.Testing.csproj" />
    <ProjectReference Include="..\..\src\Connectors\Data\InMemory\Koan.Data.Connector.InMemory.csproj" />
  </ItemGroup>
</Project>

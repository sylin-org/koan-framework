<Project Sdk="Microsoft.NET.Sdk">
  <!--
    ARCH-0091: the xUnit-AGNOSTIC slice of the shared test harness — the ARCH-0079 reflective
    AddKoan() host (KoanIntegrationHost). Deliberately carries NO xUnit dependency so it can be
    referenced by BOTH xUnit v2 (the fenced tests/Suites/Jobs projects) and xUnit v3 (the rebuilt
    harness) consumers without an Xunit.* assembly collision across the v2/v3 split.
  -->
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <IsPackable>false</IsPackable>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Hosting" Version="10.0.8" />
  </ItemGroup>
</Project>

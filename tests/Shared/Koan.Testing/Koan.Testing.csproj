<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <IsPackable>false</IsPackable>
  </PropertyGroup>
  <ItemGroup>
    <!--
      ARCH-0091: the bespoke TestPipeline/TestContext DSL has been retired in favor of Testcontainers
      4.x module fixtures + xUnit v3 (see tests/Shared/Koan.Testing.Containers and the per-suite specs).
      This project survives ONLY as a thin shim: it transitively re-exposes the ARCH-0079 reflective host
      KoanIntegrationHost (namespace Koan.Testing.Integration) so the FENCED xUnit-v2 Koan.Jobs.TestKit —
      which references this csproj and cannot be edited — keeps resolving it unchanged.

      Do NOT add source or packages here. New shared test infrastructure belongs in:
        - Koan.Testing.Hosting    (the xUnit-agnostic AddKoan() host), or
        - Koan.Testing.Containers (xUnit-v3 Testcontainers fixtures).
    -->
    <ProjectReference Include="..\Koan.Testing.Hosting\Koan.Testing.Hosting.csproj" />
  </ItemGroup>
</Project>

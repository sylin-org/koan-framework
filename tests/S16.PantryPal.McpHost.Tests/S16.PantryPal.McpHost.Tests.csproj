<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
  <TargetFramework>net10.0</TargetFramework>
    <OutputType>Exe</OutputType>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <!-- NOTE: Standard test host; containerized S16 MCP host removes need for TestServer. -->
  </PropertyGroup>
  <ItemGroup>
  <!-- Align version with other MCP/code mode test suites to avoid NU1603 mismatch -->
  <!-- Removed Microsoft.AspNetCore.Mvc.Testing; dockerized fixture runs real container instead of TestServer -->
  <PackageReference Include="Microsoft.NET.Test.Sdk" Version="18.6.0" />
  <!-- Pin to versions actually present on feed: xunit 2.9.0; keep runner at 2.8.2 if resolvable else bump too -->
  <PackageReference Include="xunit.v3" Version="3.2.2" />
  <PackageReference Include="xunit.runner.visualstudio" Version="3.1.5">
    <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    <PrivateAssets>all</PrivateAssets>
  </PackageReference>
    <PackageReference Include="AwesomeAssertions" Version="9.4.0" />
    <PackageReference Include="coverlet.collector" Version="6.0.4">
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
      <PrivateAssets>all</PrivateAssets>
    </PackageReference>
  </ItemGroup>
  <!-- Black-box: no project references; container image built separately with its own target framework (net10). -->
</Project>

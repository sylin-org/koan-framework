<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <OutputType>Exe</OutputType>
    <IsPackable>false</IsPackable>
    <Nullable>enable</Nullable>
    <!-- Inherited NU1902 from transitive OpenTelemetry deps is unrelated to this module; silence
         to keep the test project builds green until the upstream package upgrade lands. -->
    <NoWarn>$(NoWarn);NU1902</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <!-- DefaultHttpContext for the RequestSchemeAdaptiveCookieBuilder spec. -->
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="AwesomeAssertions" Version="9.4.0" />
    <!-- Microsoft.Extensions.Options is provided by the Microsoft.AspNetCore.App framework reference (NU1510). -->
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="18.6.0" />
    <PackageReference Include="xunit.v3" Version="3.2.2" />
    <PackageReference Include="xunit.runner.visualstudio" Version="3.1.5">
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
      <PrivateAssets>all</PrivateAssets>
    </PackageReference>
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\src\Koan.Web.Auth\Koan.Web.Auth.csproj" />
    <ProjectReference Include="..\..\src\Koan.Web.Auth.Abstractions\Koan.Web.Auth.Abstractions.csproj" />
    <!-- SEC-0001 §11: exercises the dev TestProvider's asymmetric JWT signing (JwtTokenService). -->
    <ProjectReference Include="..\..\src\Connectors\Web\Auth\Test\Koan.Web.Auth.Connector.Test.csproj" />
  </ItemGroup>

</Project>
